meta {
  name: POST /invitations
  type: http
  seq: 3
}

post {
  url: {{baseurlapi}}{{prefixapi}}/connection/register/invitations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "duration_times": 12,
    "duration_unit": "Days"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
